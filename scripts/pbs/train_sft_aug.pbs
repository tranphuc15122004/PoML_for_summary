#!/bin/bash
#PBS -N poml_sft_aug
#PBS -q gpuhopper
#PBS -l ncpus=12,ngpus=1,mem=120gb
#PBS -l walltime=24:00:00
#PBS -P hn98
#PBS -l storage=scratch/jp09+gdata/hn98
#PBS -o /scratch/jp09/dd9648/PoML_for_summary/logs/
#PBS -j oe

# ==============================================================================
# SFT — Augmented data (length + style constraints, 3 variants per sample)
# Supports any model via MODEL_PATH env var.
# Submit: qsub scripts/pbs/train_sft_aug.pbs
#        qsub -v MODEL_PATH=/path/to/model,EPOCHS=5 scripts/pbs/train_sft_aug.pbs
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="/scratch/jp09/dd9648/PoML_for_summary"
VENV_PATH="${PROJECT_ROOT}/.venv"
SRC_PATH="${PROJECT_ROOT}/src"
LOGS_DIR="${PROJECT_ROOT}/logs"

# Overridable via environment variables
MODEL_PATH="${MODEL_PATH:-/g/data/hn98/dd9648/models/Qwen3.5-4B}"
EPOCHS="${EPOCHS:-2.0}"
OUTPUT_DIR="${OUTPUT_DIR:-}"

mkdir -p "${LOGS_DIR}"
cd "${PROJECT_ROOT}"

echo "=============================================================="
echo "SFT Training — AUGMENTED data"
echo "Job ID:    ${PBS_JOBID}"
echo "Node:      $(hostname)"
echo "GPU:       $(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "Model:     ${MODEL_PATH}"
echo "Epochs:    ${EPOCHS}"
echo "Start:     $(date)"
echo "=============================================================="

source "${VENV_PATH}/bin/activate"
export PYTHONPATH="${SRC_PATH}:${PYTHONPATH:-}"
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export TOKENIZERS_PARALLELISM=false
export HF_DATASETS_CACHE="/scratch/jp09/dd9648/.cache/huggingface/datasets"
mkdir -p "${HF_DATASETS_CACHE}"

_SFT_START=$(date +%s)

# Step 1: Generate augmented data if not already present
_data_file="${PROJECT_ROOT}/data/sft_train.jsonl"
if [ ! -f "${_data_file}" ] || [ ! -s "${_data_file}" ]; then
    echo ">>> [1/2] Generating augmented SFT data..."
    _STEP_START=$(date +%s)
    python src/dataset/augmenter.py
    _STEP_END=$(date +%s)
    echo "  ✓ Data generation: $((_STEP_END - _STEP_START))s"
else
    lines=$(wc -l < "${_data_file}")
    echo ">>> [1/2] Augmented data found (${lines} lines) — skipping."
fi

# Step 2: Train
echo ">>> [2/2] Starting SFT (augmented)..."
_STEP_START=$(date +%s)
_LAUNCH_ARGS="--model ${MODEL_PATH} --epochs ${EPOCHS}"
if [ -n "${OUTPUT_DIR}" ]; then
    _LAUNCH_ARGS="${_LAUNCH_ARGS} --output_dir ${OUTPUT_DIR}"
fi
# shellcheck disable=SC2086
python launch_sft_aug.py ${_LAUNCH_ARGS}
_STEP_END=$(date +%s)
echo "  ✓ SFT training: $((_STEP_END - _STEP_START))s"

_SFT_END=$(date +%s)
_SFT_DURATION=$((_SFT_END - _SFT_START))
# Derive model_short for the summary message
_model_short=$(basename "${MODEL_PATH}")
echo "=============================================================="
echo "SFT (augmented) complete. Model saved: models/sft_aug_${_model_short}/"
echo "Job ID:    ${PBS_JOBID}"
echo "Duration:  $((_SFT_DURATION / 3600))h $(((_SFT_DURATION % 3600) / 60))m $((_SFT_DURATION % 60))s"
echo "End time:  $(date)"
echo "=============================================================="
