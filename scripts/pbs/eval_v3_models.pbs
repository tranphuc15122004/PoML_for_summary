#!/bin/bash
#PBS -N eval_v3_models
#PBS -q gpuhopper
#PBS -l ncpus=12,ngpus=1,mem=32gb
#PBS -l walltime=4:00:00
#PBS -P li96
#PBS -l storage=scratch/jp09+scratch/li96+gdata/hn98
#PBS -o /scratch/jp09/dd9648/PoML_for_summary/logs/eval_v3_%j.out
#PBS -e /scratch/jp09/dd9648/PoML_for_summary/logs/eval_v3_%j.err
#PBS -j oe

# ==============================================================================
# Eval — only Qwen3-4B v3 GRPO models
# ==============================================================================
# Evaluates the 4 v3 checkpoints on test.jsonl (all domains).
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="/scratch/jp09/dd9648/PoML_for_summary"
VENV_PATH="${PROJECT_ROOT}/.venv"
SRC_PATH="${PROJECT_ROOT}/src"
LOGS_DIR="${PROJECT_ROOT}/logs"
MODELS_DIR="${PROJECT_ROOT}/models"

mkdir -p "${LOGS_DIR}"
cd "${PROJECT_ROOT}"

echo "=============================================================="
echo "Eval — Qwen3-4B v3 models"
echo "Job ID:    ${PBS_JOBID}"
echo "Node:      $(hostname)"
echo "GPU:       $(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "Start:     $(date)"
echo "=============================================================="

source "${VENV_PATH}/bin/activate"
export PYTHONPATH="${SRC_PATH}:${PYTHONPATH:-}"
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export TOKENIZERS_PARALLELISM=false
export HF_DATASETS_CACHE="/scratch/jp09/dd9648/.cache/huggingface/datasets"
mkdir -p "${HF_DATASETS_CACHE}"

_EVAL_START=$(date +%s)

echo ">>> Starting evaluation of 4 v3 models..."

PYTHONPATH="${SRC_PATH}" python scripts/launch/eval.py \
    --models \
        "qwen3_base_fresh_v3=${MODELS_DIR}/grpo_qwen3_4b_base_fresh_v3/best,\
qwen3_base_sft_v3=${MODELS_DIR}/grpo_qwen3_4b_base_sft_v3/best,\
qwen3_instruct_fresh_v3=${MODELS_DIR}/grpo_qwen3_4b_instruct_fresh_v3/best,\
qwen3_instruct_sft_v3=${MODELS_DIR}/grpo_qwen3_4b_instruct_sft_v3/best" \
    --test_data data/test.jsonl

_EVAL_END=$(date +%s)
_EVAL_DURATION=$((_EVAL_END - _EVAL_START))
echo "=============================================================="
echo "Evaluation complete."
echo "Job ID:    ${PBS_JOBID}"
echo "Duration:  $((_EVAL_DURATION / 3600))h $(((_EVAL_DURATION % 3600) / 60))m $((_EVAL_DURATION % 60))s"
echo "End time:  $(date)"
echo "=============================================================="
