#!/bin/bash
#PBS -N poml_grpo
#PBS -q gpuhopper
#PBS -l ncpus=24,ngpus=1,mem=120gb
#PBS -l walltime=24:00:00
#PBS -P hn98
#PBS -l storage=scratch/jp09+gdata/hn98
#PBS -o /scratch/jp09/dd9648/PoML_for_summary/logs/grpo_%j.out
#PBS -e /scratch/jp09/dd9648/PoML_for_summary/logs/grpo_%j.err
#PBS -j oe

# ==============================================================================
# PoML for Summary — GRPO Training
# ==============================================================================
# Align SFT model using multi-objective RL:
#   - R_acc  (ROUGE-L)
#   - R_len  (word count adherence)
#   - R_sent (sentence count adherence)
#
# Usage:
#   qsub scripts/pbs/train_grpo.pbs                              # default (H200)
#   qsub -v GPU_MODEL=v100 scripts/pbs/train_grpo.pbs             # V100 override
#   qsub -v RESUME=models/grpo/checkpoint-300 scripts/pbs/train_grpo.pbs  # resume
#   qsub -v LR=3e-7,NUM_GEN=6,TOTAL_STEPS=1200 scripts/pbs/train_grpo.pbs  # tuning
# ==============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths (Gadi-specific)
# ---------------------------------------------------------------------------
PROJECT_ROOT="/scratch/jp09/dd9648/PoML_for_summary"
VENV_PATH="${PROJECT_ROOT}/.venv"
SRC_PATH="${PROJECT_ROOT}/src"
LOGS_DIR="${PROJECT_ROOT}/logs"
LOCAL_MODEL="/g/data/hn98/dd9648/models/Qwen2.5-3B-Instruct"
OUTPUT_DIR="${PROJECT_ROOT}/models/grpo"

mkdir -p "${LOGS_DIR}" "${OUTPUT_DIR}"
cd "${PROJECT_ROOT}"

# ---------------------------------------------------------------------------
# Overridable hyper-parameters (via environment variables)
# ---------------------------------------------------------------------------
LR="${LR:-5e-7}"
NUM_GEN="${NUM_GEN:-4}"              # K completions per prompt
BETA="${BETA:-0.04}"                 # KL penalty coefficient
TOTAL_STEPS="${TOTAL_STEPS:-800}"
RESUME="${RESUME:-}"                 # checkpoint dir to resume from

# ---------------------------------------------------------------------------
# GPU auto-detect
# ---------------------------------------------------------------------------
if [ -z "${GPU_MODEL:-}" ]; then
    _GPU=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)
    case "${_GPU}" in
        *H200*|*Hopper*) GPU_MODEL="h200" ;;
        *A100*)          GPU_MODEL="a100" ;;
        *V100*)          GPU_MODEL="v100" ;;
        *)               GPU_MODEL="a100" ;;
    esac
    echo "  [auto-detect] GPU_MODEL=${GPU_MODEL} ← ${_GPU}"
fi

case "${GPU_MODEL}" in
    h200)
        DTYPE="bf16"
        BATCH=12
        GRAD_ACCUM=1   # effective 12 prompts/update
        ;;
    a100)
        DTYPE="bf16"
        BATCH=4
        GRAD_ACCUM=2   # effective 8
        ;;
    v100)
        DTYPE="fp16"
        BATCH=2
        GRAD_ACCUM=2   # effective 4
        ;;
    *)
        DTYPE="bf16"
        BATCH=12
        GRAD_ACCUM=1
        ;;
esac

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
source "${VENV_PATH}/bin/activate"
export PYTHONPATH="${SRC_PATH}:${PYTHONPATH}"
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export TOKENIZERS_PARALLELISM=false
export HF_DATASETS_CACHE="/scratch/jp09/dd9648/.cache/huggingface/datasets"
mkdir -p "${HF_DATASETS_CACHE}"

# ---------------------------------------------------------------------------
# Print job info
# ---------------------------------------------------------------------------
echo "=============================================================="
echo "GRPO Training"
echo "Job ID:    ${PBS_JOBID}"
echo "Node:      $(hostname)"
echo "GPU:       $(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "GPU Model: ${GPU_MODEL}"
echo "Dtype:     ${DTYPE}"
echo "Batch:     ${BATCH} (eff: $((BATCH * GRAD_ACCUM)))"
echo "LR:        ${LR}"
echo "Num gen:   ${NUM_GEN}"
echo "Beta:      ${BETA}"
echo "Steps:     ${TOTAL_STEPS}"
echo "Resume:    ${RESUME:-none}"
echo "Model:     ${LOCAL_MODEL}"
echo "Output:    ${OUTPUT_DIR}"
echo "Start:     $(date)"
echo "=============================================================="

# ---------------------------------------------------------------------------
# Write per-GPU config overrides
# ---------------------------------------------------------------------------
OVERRIDE_CFG="${LOGS_DIR}/grpo_cfg_${PBS_JOBID}.json"
python -c "
import json
print(json.dumps({
    'per_device_train_batch_size': ${BATCH},
    'gradient_accumulation_steps': ${GRAD_ACCUM},
    'bf16': $([ '${DTYPE}' = 'bf16' ] && echo 'true' || echo 'false'),
    'fp16': $([ '${DTYPE}' = 'fp16' ] && echo 'true' || echo 'false'),
    'gradient_checkpointing': $([ '${GPU_MODEL}' = 'v100' ] && echo 'true' || echo 'false'),
    'reward_weight_accuracy': 0.5,
    'reward_weight_length': 0.3,
    'reward_weight_sentence': 0.2,
}))" > "${OVERRIDE_CFG}"

# ---------------------------------------------------------------------------
# Build resume arg
# ---------------------------------------------------------------------------
RESUME_ARG=""
if [ -n "${RESUME}" ] && [ -d "${RESUME}" ]; then
    RESUME_ARG="--resume ${RESUME}"
fi

# ---------------------------------------------------------------------------
# GRPO Training
# ---------------------------------------------------------------------------
echo ""
echo ">>> Starting GRPO training..."

python src/SFT_GRPO/train_grpo.py \
    --model_name "${LOCAL_MODEL}" \
    --output_dir "${OUTPUT_DIR}" \
    --lr "${LR}" \
    --num_generations "${NUM_GEN}" \
    --beta "${BETA}" \
    --total_steps "${TOTAL_STEPS}" \
    --train_data "data/grpo_train.jsonl" \
    --val_data "data/grpo_val.jsonl" \
    --config "${OVERRIDE_CFG}" \
    ${RESUME_ARG}

echo ""
echo "=============================================================="
echo "GRPO complete."
echo "Checkpoints: ${OUTPUT_DIR}/"
echo "End time:    $(date)"
echo "=============================================================="