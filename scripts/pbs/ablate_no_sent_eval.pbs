#!/bin/bash
#PBS -N ablate_no_sent_eval
#PBS -q gpuhopper
#PBS -l ncpus=12,ngpus=1,mem=32gb
#PBS -l walltime=2:00:00
#PBS -P li96
#PBS -l storage=scratch/jp09+scratch/li96+gdata/hn98
#PBS -o /scratch/jp09/dd9648/PoML_for_summary/logs/ablate_no_sent_eval_%j.out
#PBS -e /scratch/jp09/dd9648/PoML_for_summary/logs/ablate_no_sent_eval_%j.err
#PBS -j oe

# ==============================================================================
# Eval — Ablation models (no sentence reward)
# ==============================================================================
# Evaluates the 2 ablation checkpoints on test.jsonl (all domains):
#   1. ablate_no_sent_qwen3_base_fresh  — GRPO fresh (no SFT), w_sent=0.0
#   2. ablate_no_sent_qwen3_base_sft    — GRPO from SFT,      w_sent=0.0
# Also evaluates per-domain test sets.
# ==============================================================================

set -euo pipefail

PROJECT_ROOT="/scratch/jp09/dd9648/PoML_for_summary"
VENV_PATH="${PROJECT_ROOT}/.venv"
SRC_PATH="${PROJECT_ROOT}/src"
LOGS_DIR="${PROJECT_ROOT}/logs"
MODELS_DIR="${PROJECT_ROOT}/models"

mkdir -p "${LOGS_DIR}"
cd "${PROJECT_ROOT}"

echo "=============================================================="
echo "Eval — Ablation models (no sentence reward)"
echo "Job ID:    ${PBS_JOBID}"
echo "Node:      $(hostname)"
echo "GPU:       $(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "Start:     $(date)"
echo "=============================================================="

source "${VENV_PATH}/bin/activate"
export PYTHONPATH="${SRC_PATH}:${PYTHONPATH:-}"
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export TOKENIZERS_PARALLELISM=false
export HF_DATASETS_CACHE="/scratch/jp09/dd9648/.cache/huggingface/datasets"
mkdir -p "${HF_DATASETS_CACHE}"

_EVAL_START=$(date +%s)

echo ">>> Starting evaluation of 2 ablation models..."

# Evaluate on combined test set
PYTHONPATH="${SRC_PATH}" python scripts/launch/eval.py \
    --models \
        "ablate_no_sent_fresh=${MODELS_DIR}/ablate_no_sent_qwen3_base_fresh/best,\
ablate_no_sent_sft=${MODELS_DIR}/ablate_no_sent_qwen3_base_sft/best" \
    --test_data data/test.jsonl

# Evaluate on per-domain test sets
for DOMAIN in vietnews wikilingua vlsp vims; do
    TEST_FILE="data/test_${DOMAIN}.jsonl"
    if [ -f "${TEST_FILE}" ]; then
        echo ""
        echo ">>> Evaluating on ${DOMAIN}..."
        PYTHONPATH="${SRC_PATH}" python scripts/launch/eval.py \
            --models \
                "ablate_no_sent_fresh=${MODELS_DIR}/ablate_no_sent_qwen3_base_fresh/best,\
ablate_no_sent_sft=${MODELS_DIR}/ablate_no_sent_qwen3_base_sft/best" \
            --test_data "${TEST_FILE}"
    fi
done

_EVAL_END=$(date +%s)
_EVAL_DURATION=$((_EVAL_END - _EVAL_START))
echo "=============================================================="
echo "Evaluation complete."
echo "Job ID:    ${PBS_JOBID}"
echo "Duration:  $((_EVAL_DURATION / 3600))h $(((_EVAL_DURATION % 3600) / 60))m $((_EVAL_DURATION % 60))s"
echo "End time:  $(date)"
echo "=============================================================="
