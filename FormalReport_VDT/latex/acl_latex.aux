\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Reward-hacking mitigation from v3 to v5, computed from stored generations with the current reward implementation. Deg.\% is the fraction flagged as degenerate by the detection filter; $R_{\text  {acc}}=0$\% is the fraction receiving zero content reward; Mean $R_{\text  {acc}}$ is the average content reward. The comparison is a package-level ablation and does not isolate any single change.\relax }}{11}{table.caption.16}}
\newlabel{tab:reward-mitigation}{{6}{11}{Reward-hacking mitigation from v3 to v5, computed from stored generations with the current reward implementation. Deg.\% is the fraction flagged as degenerate by the detection filter; $R_{\text {acc}}=0$\% is the fraction receiving zero content reward; Mean $R_{\text {acc}}$ is the average content reward. The comparison is a package-level ablation and does not isolate any single change.\relax }{table.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Paired v3--v5 examples of the two most severe reward-hacking modes from VietNews. Each card shows a reference summary (gray), the failed v3 output (red), and the recovered v5 output (green), together with failure or recovery indicators. Left: repetition loop (Base fresh; \texttt  {assistant} repeated $128$ times). Right: punctuation-driven length explosion (Base SFT-init; $245$ words of periods).\relax }}{12}{figure.caption.17}}
\newlabel{fig:reward-cases}{{4}{12}{Paired v3--v5 examples of the two most severe reward-hacking modes from VietNews. Each card shows a reference summary (gray), the failed v3 output (red), and the recovered v5 output (green), together with failure or recovery indicators. Left: repetition loop (Base fresh; \texttt {assistant} repeated $128$ times). Right: punctuation-driven length explosion (Base SFT-init; $245$ words of periods).\relax }{figure.caption.17}{}}
