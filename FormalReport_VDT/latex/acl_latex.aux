\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Two-panel trade-off trajectory showing ROUGE-2 versus absolute summary length distance for the Base and Instruct backbones on VietNews (left) and WikiLingua (right). Arrowed lines display the observed stage sequence (Raw $\rightarrow $ SFT $\rightarrow $ SFT+GRPO v5), while standalone markers show the lower content scores of Fresh GRPO v5 without SFT initialization.\relax }}{10}{figure.caption.11}}
\newlabel{fig:stage-ablation-trajectory}{{3}{10}{Two-panel trade-off trajectory showing ROUGE-2 versus absolute summary length distance for the Base and Instruct backbones on VietNews (left) and WikiLingua (right). Arrowed lines display the observed stage sequence (Raw $\rightarrow $ SFT $\rightarrow $ SFT+GRPO v5), while standalone markers show the lower content scores of Fresh GRPO v5 without SFT initialization.\relax }{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Reward-hacking mitigation from v3 to v5, computed from stored generations with the current reward implementation. Deg.\% is the fraction flagged as degenerate by the detection filter; $R_{\text  {acc}}=0$\% is the fraction receiving zero content reward; Mean $R_{\text  {acc}}$ is the average content reward. The comparison is a package-level ablation and does not isolate any single change\relax }}{10}{table.caption.16}}
\newlabel{tab:reward-mitigation}{{6}{10}{Reward-hacking mitigation from v3 to v5, computed from stored generations with the current reward implementation. Deg.\% is the fraction flagged as degenerate by the detection filter; $R_{\text {acc}}=0$\% is the fraction receiving zero content reward; Mean $R_{\text {acc}}$ is the average content reward. The comparison is a package-level ablation and does not isolate any single change\relax }{table.caption.16}{}}
